# Keyaos — Worker Secrets (local development)
# Copy to .dev.vars and fill in your values.
# Production secrets: set via `wrangler secret put <NAME>`

# ─── Core (required) ─────────────────────────────────────
ADMIN_TOKEN=changeme
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# ─── Platform (optional — enables multi-tenancy) ─────────
# PLATFORM_OWNER_ID=user_xxxxx
# CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# CLERK_SECRET_KEY=sk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ─── Model Catalog Sync ──────────────────────────────────
# By default the worker syncs model_catalog from keyaos.com every minute.
# Set LOCAL_SYNC=1 to run local three-phase sync (requires system keys below).
# LOCAL_SYNC=1

# ─── Provider System Keys (optional — only when LOCAL_SYNC=1) ──
# The sync service fetches live models from provider APIs.
# DEEPSEEK_KEY=sk-xxxxx
# OPENAI_KEY=sk-proj-xxxxx
# GEMINI_KEY=AIzaxxxxx
# ANTHROPIC_KEY=sk-ant-api03-xxxxx
# XAI_KEY=xai-xxxxx
