	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "node scripts/build-search-index.mjs && vite build",
		"deploy": "pnpm build && wrangler d1 migrations apply keyaos-db --remote && wrangler deploy",
		"test": "vitest run",
		"test:api": "node --env-file=.env.local --experimental-strip-types --no-warnings --test tests/e2e/**/*.test.ts",
		"lint": "biome check --write .",
		"db:setup:local": "wrangler d1 execute keyaos-db --local --file=./migrations/0001_initial.sql",
		"db:setup:remote": "wrangler d1 execute keyaos-db --remote --file=./migrations/0001_initial.sql"
	},
